# Transporte MCP: stdio para uso local, streamable-http para servidor HTTP.
MCP_TRANSPORT=stdio

# Fuente experimental.
SPORTS_PROVIDER=flashscore
FLASHSCORE_BASE_URL=https://www.flashscore.pe/
FLASHSCORE_HEADLESS=true
FLASHSCORE_TIMEOUT_MS=15000

# Cache. Para pruebas puedes bajar a 1, pero el valor responsable es 5+.
FLASHSCORE_REFRESH_SECONDS=5
FLASHSCORE_CACHE_TTL_SECONDS=8

# Watch tool.
FLASHSCORE_MAX_WATCH_SECONDS=120
